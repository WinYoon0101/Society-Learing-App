<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7EE"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:src="@drawable/text_logo"
            android:scaleType="centerInside" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconSearch"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#283633" />

            <ImageView
                android:id="@+id/iconLogout"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_logout"
                app:tint="#FF5252" />
        </LinearLayout>
    </RelativeLayout>

    <!-- TAB -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="6dp">

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgHome"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_home"
                app:tint="@color/tab_icon_color" />

            <View
                android:id="@+id/lineHome"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:background="#0B8A00" />
        </LinearLayout>

        <!-- FRIEND -->
        <LinearLayout
            android:id="@+id/tabFriend"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgFriend"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_group"
                app:tint="@color/tab_icon_color" />

            <View
                android:id="@+id/lineFriend"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:background="#0B8A00"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- CHAT -->
        <LinearLayout
            android:id="@+id/tabChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgChat"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_chat"
                app:tint="@color/tab_icon_color" />

            <View
                android:id="@+id/lineChat"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:background="#0B8A00"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- LIBRARY -->
        <LinearLayout
            android:id="@+id/tabLibrary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgLibrary"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_library"
                app:tint="@color/tab_icon_color" />

            <View
                android:id="@+id/lineLibrary"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:background="#0B8A00"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- NOTIFY -->
        <LinearLayout
            android:id="@+id/tabNotify"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgNotify"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_notify"
                app:tint="@color/tab_icon_color" />

            <View
                android:id="@+id/lineNotify"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:background="#0B8A00"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:id="@+id/tabProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/tab_icon_color" />

            <View
                android:id="@+id/lineProfile"
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:background="#0B8A00"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>