<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card"
    android:elevation="1dp">
    <!-- Ghi chú: Mình dùng bg_card cho nền trắng bo góc, nếu lỗi bạn có thể thay bằng background="#FFFFFF" -->

    <!-- Hình thumbnail của bài viết (Dùng CardView bọc ngoài để bo góc tròn) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardThumbnail"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgPostThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_image" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvPostContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Hướng dẫn cấu hình Firebase từ A-Z cho người mới bắt đầu..."
        android:textColor="#283633"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/btnMoreOptions"
        app:layout_constraintStart_toEndOf="@id/cardThumbnail"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnMoreOptions"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="4dp"
        android:src="@drawable/ic_more_vert"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tác giả -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgAuthorAvatar"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginBottom="4dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_user"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:layout_constraintBottom_toBottomOf="@id/cardThumbnail"
        app:layout_constraintStart_toStartOf="@id/tvPostContent" />

    <TextView
        android:id="@+id/tvAuthorName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Phạm Việt Quang Huy • Đã lưu"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/imgAuthorAvatar"
        app:layout_constraintStart_toEndOf="@id/imgAuthorAvatar"
        app:layout_constraintTop_toTopOf="@id/imgAuthorAvatar" />

</androidx.constraintlayout.widget.ConstraintLayout>