<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7EE">

    <LinearLayout
        android:id="@+id/tabHome"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tabFriend">

        <ImageView
            android:id="@+id/imgHome"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_home"
            app:tint="@color/tab_icon_color" />

        <View
            android:id="@+id/lineHome"
            android:layout_width="28dp"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:background="#0B8A00" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabFriend"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/tabHome"
        app:layout_constraintEnd_toStartOf="@id/tabChat">

        <ImageView
            android:id="@+id/imgFriend"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_group"
            app:tint="@color/tab_icon_color" />

        <View
            android:id="@+id/lineFriend"
            android:layout_width="28dp"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:background="#0B8A00"
            android:visibility="invisible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabChat"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/tabFriend"
        app:layout_constraintEnd_toStartOf="@id/tabLibrary">

        <ImageView
            android:id="@+id/imgChat"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_chat"
            app:tint="@color/tab_icon_color" />

        <View
            android:id="@+id/lineChat"
            android:layout_width="28dp"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:background="#0B8A00"
            android:visibility="invisible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabLibrary"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/tabChat"
        app:layout_constraintEnd_toStartOf="@id/tabNotify">

        <ImageView
            android:id="@+id/imgLibrary"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_library"
            app:tint="@color/tab_icon_color" />

        <View
            android:id="@+id/lineLibrary"
            android:layout_width="28dp"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:background="#0B8A00"
            android:visibility="invisible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabNotify"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/tabLibrary"
        app:layout_constraintEnd_toStartOf="@id/tabProfile">

        <ImageView
            android:id="@+id/imgNotify"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_notify"
            app:tint="@color/tab_icon_color" />

        <View
            android:id="@+id/lineNotify"
            android:layout_width="28dp"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:background="#0B8A00"
            android:visibility="invisible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabProfile"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/tabNotify"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_profile"
            app:tint="@color/tab_icon_color" />

        <View
            android:id="@+id/lineProfile"
            android:layout_width="28dp"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:background="#0B8A00"
            android:visibility="invisible" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/profileHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tabProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgCover"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/cover_sample"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_margin="12dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#FFFFFF"

            android:text="Edit"
            android:textAllCaps="false"
            android:textColor="#000"
            app:layout_constraintBottom_toBottomOf="@id/imgCover"
            app:layout_constraintEnd_toEndOf="@id/imgCover" />

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="centerCrop"
            android:src="@drawable/cover_sample"
            android:background="@drawable/bg_cirle"
            android:clipToOutline="true"

            app:layout_constraintTop_toBottomOf="@id/imgCover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"

            android:layout_marginTop="-55dp"/>

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minh Nguyen"
            android:textSize="20sp"
            android:textStyle="bold"

            app:layout_constraintTop_toBottomOf="@id/imgAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"

            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvBio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hello world"
            android:textSize="14sp"
            android:textColor="#666"
            android:gravity="center"

            app:layout_constraintTop_toBottomOf="@id/tvUserName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"

            android:layout_marginTop="4dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>

        <TextView
            android:id="@+id/tvStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="482 friends • 12 groups"
            android:textSize="13sp"
            android:textColor="#888"
            android:gravity="center"

            app:layout_constraintTop_toBottomOf="@id/tvBio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"

            android:layout_marginTop="6dp"/>
        <Button
            android:id="@+id/btnAddStory"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:text="Thêm tin"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"

            app:layout_constraintTop_toBottomOf="@id/tvStats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnMessage"

            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnMessage"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:text="Message"
            android:textAllCaps="false"
            android:textColor="#000"
            android:backgroundTint="#ADC6FF"

            app:layout_constraintTop_toTopOf="@id/btnAddStory"
            app:layout_constraintStart_toEndOf="@id/btnAddStory"
            app:layout_constraintEnd_toEndOf="parent"

            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"/>

        <LinearLayout
            android:id="@+id/layoutIntro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card"

            app:layout_constraintTop_toBottomOf="@id/btnAddStory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_margin="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intro"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000"
                android:layout_marginBottom="12dp"/>

            <!-- Item -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lives in Hanoi, Vietnam"
                    android:textSize="14sp"
                    android:textColor="#444"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Item -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_location"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="From Da Nang"
                    android:textSize="14sp"
                    android:textColor="#444"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Item -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Joined March 2021"
                    android:textSize="14sp"
                    android:textColor="#444"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Item -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_heart"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Interested in Urban Ecology, Coffee"
                    android:textSize="14sp"
                    android:textColor="#444"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Button -->
            <Button
                android:id="@+id/btnEditDetails"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Edit Details"
                android:textAllCaps="false"
                android:textColor="#000"
                android:backgroundTint="#E0E0E0"/>

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

