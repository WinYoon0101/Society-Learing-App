<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FDF4">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TỔNG KẾT PHIÊN HỌC"
            android:fontFamily="sans-serif-black"
            android:textSize="22sp"
            android:textColor="#064E3B"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#D1FAE5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtEfficiency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="85%"
                    android:textSize="56sp"
                    android:textStyle="bold"
                    android:textColor="#10B981"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MỨC ĐỘ TẬP TRUNG"
                    android:letterSpacing="0.1"
                    android:textSize="12sp"
                    android:textColor="#059669"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phân tích cảm xúc"
            android:layout_marginTop="32dp"
            android:textStyle="bold"
            android:textColor="#1E293B"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tập trung "
                    android:textSize="12sp"
                    android:textColor="#64748B"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressNeutral"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    app:trackThickness="8dp"
                    app:trackCornerRadius="4dp"
                    app:indicatorColor="#3B82F6"
                    app:trackColor="#EFF6FF"
                    android:progress="70"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hào hứng "
                    android:textSize="12sp"
                    android:textColor="#64748B"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressHappy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    app:trackThickness="8dp"
                    app:trackCornerRadius="4dp"
                    app:indicatorColor="#10B981"
                    app:trackColor="#F0FDF4"
                    android:progress="40"/>



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Căng thẳng "
                    android:textSize="12sp"
                    android:textColor="#64748B"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressStress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:trackThickness="8dp"
                    app:trackCornerRadius="4dp"
                    app:indicatorColor="#F87171"
                    app:trackColor="#FEF2F2"
                    android:progress="15"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xao nhãng"
                    android:textSize="12sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="16dp"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressSurprised"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:trackThickness="8dp"
                    app:trackCornerRadius="4dp"
                    app:indicatorColor="#FACC15"
                    app:trackColor="#FEFCE8"
                    android:progress="0"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAdvice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#D1FAE5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="24sp"
                    android:layout_marginEnd="16dp"/>

                <TextView
                    android:id="@+id/txtAISummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đang phân tích dữ liệu học tập của bạn..."
                    android:textColor="#064E3B"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Hoàn thành"
            android:backgroundTint="#10B981"
            app:cornerRadius="16dp"
            android:textStyle="bold"
            android:layout_marginBottom="40dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>